rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Admins can see all, users can see themselves, or if the document's email matches the authenticated user's email
      allow read: if isOwner(userId) || isAdmin() || (isSignedIn() && request.auth.token.email != null && resource.data.email.lower() == request.auth.token.email.lower());
      
      // Allow bootstrapping: any signed-in user can create their own document if they are saving their own authenticated email
      allow create: if isAdmin() || (isOwner(userId) && request.auth.token.email != null && request.resource.data.email.lower() == request.auth.token.email.lower());
      
      allow delete: if isAdmin();
      
      // Admins can update anything, users can update their own TFA settings
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tfaSecret', 'tfaEnabled']));
    }

    // Login attempts (Public write, Admin read)
    match /login_attempts/{attemptId} {
      allow create: if true; // Allow logging even before full auth
      allow read, list: if isAdmin();
    }

    // Clients & Price Lists
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /prices/{priceId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }
  }
}
