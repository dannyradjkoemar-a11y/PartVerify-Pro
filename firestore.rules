rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Admins can see all, users can see themselves
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow bootstrapping: the designated admins can create their own doc
      // Others require admin rights
      allow create: if isAdmin() || (isOwner(userId) && (request.auth.token.email.lower() == 'partverify-pro@outlook.com' || request.auth.token.email.lower() == 'dannyradjkoemar@gmail.com'));
      
      allow delete: if isAdmin();
      
      // Admins can update anything, users can update their own TFA settings
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tfaSecret', 'tfaEnabled']));
    }

    // Login attempts (Public write, Admin read)
    match /login_attempts/{attemptId} {
      allow create: if true; // Allow logging even before full auth
      allow read, list: if isAdmin();
    }

    // Clients & Price Lists
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /prices/{priceId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }
  }
}
